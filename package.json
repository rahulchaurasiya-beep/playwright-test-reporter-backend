{
  "name": "playwright-reporter-backend",
  "version": "1.0.0",
  "description": "Backend API for playwright-rocketium-reporter",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "summary": "node scripts/print-run-summary.js",
    "migrate:s3": "node scripts/migrate-uploads-to-s3.mjs",
    "migrate:s3:dry": "node scripts/migrate-uploads-to-s3.mjs --dry-run",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres"
  },
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1063.0",
    "@aws-sdk/lib-storage": "^3.1063.0",
    "@aws-sdk/s3-request-presigner": "^3.1063.0",
    "bcryptjs": "^3.0.3",
    "cors": "2.8.6",
    "express": "5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "2.1.1",
    "pg": "8.16.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "2.0.0",
    "@types/node": "24.0.0",
    "@types/pg": "8.15.4",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
