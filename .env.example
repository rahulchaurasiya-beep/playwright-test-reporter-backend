PORT=3000
DATABASE_SSL=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/playwright_reporter
# Artifact storage: local (default) or s3
ARTIFACT_STORAGE=s3
UPLOADS_DIR=./uploads

# S3 (when ARTIFACT_STORAGE=s3)
AWS_REGION=
AWS_S3_BUCKET=
AWS_S3_PREFIX=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ARTIFACT_URL_MODE=proxy
S3_PRESIGN_EXPIRES_SEC=3600

# JWT auth for dashboard users
JWT_SECRET=
JWT_EXPIRES_IN=7d

# UI dashboard uses JWT on GET/PATCH/POST /api/ui/projects
DATA_DIR=./data